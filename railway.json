{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "echo \"$GOOGLE_CREDENTIALS_BASE64\" | base64 -d > /tmp/gcp-credentials.json && GOOGLE_APPLICATION_CREDENTIALS=/tmp/gcp-credentials.json uvicorn agent_backend.main:app --host 0.0.0.0 --port $PORT"
  }
}
