# 필수 환경변수 — 이 파일을 .env로 복사한 뒤 값을 채우세요
OPENAI_API_KEY=sk-proj-...
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/credentials.json

# 선택 — 설정 시 분석 완료 후 Slack 알림 발송
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# 배포 시 필수 — Next.js 프록시만 호출하도록 제한 (openssl rand -hex 32로 생성).
# dashboard/.env.local에도 같은 값을 BACKEND_SHARED_SECRET으로 설정해야 함.
# 로컬 개발(미설정)에서는 인증 검사를 건너뜀.
# BACKEND_SHARED_SECRET=
